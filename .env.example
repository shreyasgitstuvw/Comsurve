# ─────────────────────────────────────────────────────────────────────────────
# MCEI — Environment Variables
# Copy to .env and fill in the values before running.
#
# Secret tiers:
#   CRITICAL  — system cannot start without these
#   DEGRADED  — one data source disabled per missing key; warnings at startup
#   OPTIONAL  — reduced functionality only
# ─────────────────────────────────────────────────────────────────────────────


# ── CRITICAL ──────────────────────────────────────────────────────────────────

# Gemini API key — required for embedding, causality, prediction, evaluation.
# Free tier: 15 RPM / 1500 req/day  |  Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=


# ── DEGRADED (one data source disabled per missing key) ───────────────────────

# newsdata.io — primary news source (200 req/day free tier)
NEWSDATA_API_KEY=

# aisstream.io — AIS vessel tracking (free tier available)
AISSTREAM_API_KEY=

# FRED (Federal Reserve) — LNG/copper historical prices
FRED_API_KEY=

# EIA — energy price historical data
EIA_API_KEY=


# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# newsapi.ai — news fallback when newsdata.io is rate-limited
NEWSAPI_AI_KEY=

# Commodities-API — price fallback when yfinance is unavailable (100 req/mo free)
COMMODITIES_API_KEY=

# OpenSky Network — aircraft tracking (authenticated = higher rate limits)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Copernicus Data Space — Sentinel-1/2 satellite product download
CDSE_USERNAME=
CDSE_PASSWORD=


# ── SECURITY ──────────────────────────────────────────────────────────────────

# API key for the FastAPI service. All endpoints require X-API-Key header.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty ONLY for local development (startup prints a warning).
MCEI_API_KEY=

# CORS allowed origins (comma-separated). Override in production.
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501


# ── APPLICATION ───────────────────────────────────────────────────────────────

DB_PATH=mcei.db
QDRANT_PATH=./qdrant_data
LOG_LEVEL=INFO

# Optional: write logs to a rotating file (10 MB x 5 backups) + stdout.
# Leave empty to log to stdout only (recommended for Docker deployments).
LOG_FILE=

API_HOST=127.0.0.1
API_PORT=8000


# ── ALERTING ──────────────────────────────────────────────────────────────────

# POST webhook for failure alerts (Slack, Discord, PagerDuty, custom endpoint).
# Payload: {"level": "error|warning", "event": "...", "job": "...", "message": "..."}
# Leave empty to log-only (no HTTP call).
MCEI_ALERT_WEBHOOK_URL=
